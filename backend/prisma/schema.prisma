generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id        Int      @id @default(autoincrement())
  email     String   @unique
  name      String
  role      String   // SUPER_ADMIN, TA, HR, IT_ADMIN, ASSET, DISPATCH, QA, SUPPORT
  password  String?  // For local bypass
  ms_oid    String?  // Microsoft Object ID
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  logs      ActivityLog[]
}

model OnboardingTicket {
  id               Int      @id @default(autoincrement())
  ticketNumber     String   @unique
  firstName        String
  middleName       String?
  lastName         String
  fullName         String
  contactNumber    String
  personalEmail    String
  doj              DateTime
  designation      String
  department       String
  workType         String
  officeLocation   String
  projectName      String
  reportingManager String
  accountManager   String
  ndaSigned        Boolean  @default(false)
  pastExperience   String?
  address          String
  country          String
  state            String
  city             String
  zip              String   @default("")
  laptopRequired   Boolean  @default(true)
  dispatchRequired Boolean  @default(true)
  remarks          String?
  
  // Generated Fields
  company          String   @default("Eastern Enterprise.com")
  employeeId       String?  @unique
  username         String?  @unique
  companyEmailId   String?  @unique

  // Keka HR sync fields
  kekaEmployeeId   String?  @unique
  kekaProfileUrl   String?
  kekaHrNotes      String?

  status           String   @default("HR Verification") // HR Verification, BGV In Progress, IT Account Creation, Asset Preparation, Dispatch Pending, QA Verification, Ready for Joining, Joined, Closed

  hrDetails        HRDetails?
  itDetails        ITDetails?
  assetDetails     AssetDetails?
  dispatchDetails  DispatchDetails?
  qaDetails        QADetails?
  hardwareRequest  HardwareRequest?
  activityLogs     ActivityLog[]
  credentialSheet  CredentialSheet?

  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt
}

model HRDetails {
  id                  Int       @id @default(autoincrement())
  ticketId            Int       @unique
  ticket              OnboardingTicket @relation(fields: [ticketId], references: [id])

  // BGV Verification
  bgvStatus           String    @default("Pending") // Pending, In Progress, Cleared, Failed
  approvalType        String?   // BGV_CLEARED | EXCEPTION_APPROVAL
  approved            Boolean   @default(false)
  hrRemarks           String?

  // Exception Approval fields
  bgvProof            String?   // Base64 file URL
  bgvProofName        String?
  bgvProofType        String?
  bgvExceptionReason  String?
  bgvUploadedBy       String?
  bgvUploadedAt       DateTime?
  bgvApprovedAt       DateTime?

  // Induction Schedule (DOJ-locked)
  inductionSchedule   DateTime?
  meetingLink         String?
  hrCoordinator       String?
  inductionNotes      String?

  // Legacy
  documentsUploaded   Boolean   @default(false)
}

model ITDetails {
  id                  Int      @id @default(autoincrement())
  ticketId            Int      @unique
  ticket              OnboardingTicket @relation(fields: [ticketId], references: [id])
  adCreated           Boolean  @default(false)
  o365LicenseAssigned Boolean  @default(false)
  mfaEnabled          Boolean  @default(false)
  vpnCreated          Boolean  @default(false)
  pitCreated          Boolean  @default(false)
  assignedO365License String?
  snipeItUserCreated  Boolean  @default(false)
  tempPassword        String?
}

model AssetDetails {
  id               Int      @id @default(autoincrement())
  ticketId         Int      @unique
  ticket           OnboardingTicket @relation(fields: [ticketId], references: [id])
  assetTag         String?
  serialNumber     String?
  hostname         String?
  ram              String?
  storage          String?
  osVersion        String?
  antivirusStatus  String?
  assignedEngineer String?
  deviceCondition  String?
  // Asset validation from Snipe-IT
  assetValidated   Boolean  @default(false)
  assetSnipeId     Int?
  assetStatusName  String?
  // Handover & GetPass
  handoverType     String?   // "OFFICE" | "COURIER"
  getpassUploaded  Boolean   @default(false)
  getpassFileName  String?
  getpassFileContent String? // Base64 encoded
  getpassFileType  String?
  getpassUploadedBy String?
  getpassUploadedAt DateTime?
  getpassPasswordHint String?
}

model DispatchDetails {
  id               Int      @id @default(autoincrement())
  ticketId         Int      @unique
  ticket           OnboardingTicket @relation(fields: [ticketId], references: [id])
  courierScheduled Boolean  @default(false)
  courierVendor    String?  // "SHREE_MARUTI" | "DTDC" | "OTHER"
  trackingId       String?
  dispatchDate     DateTime?
  deliveryStatus   String?  // "Dispatched" | "In Transit" | "Delivered" | null
  deliveredAt      DateTime?
  deliveredBy      String?
  deliveryNote     String?
  podUploaded      Boolean  @default(false)
}

model QADetails {
  id                    Int      @id @default(autoincrement())
  ticketId              Int      @unique
  ticket                OnboardingTicket @relation(fields: [ticketId], references: [id])
  serialNumberVerified  Boolean  @default(false)
  osConfigured          Boolean  @default(false)
  softwareInstalled     Boolean  @default(false)
  adChecked             Boolean  @default(false)
  o365Checked           Boolean  @default(false)
  mfaChecked            Boolean  @default(false)
  vpnChecked            Boolean  @default(false)
  laptopChecked         Boolean  @default(false)
  snipeItChecked        Boolean  @default(false)
  softwareChecked       Boolean  @default(false)
  completed             Boolean  @default(false)
}

model ActivityLog {
  id        Int      @id @default(autoincrement())
  ticketId  Int
  ticket    OnboardingTicket @relation(fields: [ticketId], references: [id])
  userId    Int?
  user      User?    @relation(fields: [userId], references: [id])
  action    String
  details   String?
  timestamp DateTime @default(now())
}

model HardwareRequest {
  id              Int              @id @default(autoincrement())
  ticketId        Int              @unique
  ticket          OnboardingTicket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  hardwareModel   String?
  hardwareComment String?
  hardwareStatus  String           @default("PENDING") // PENDING, SUBMITTED
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model LicenseInventory {
  id               Int              @id @default(autoincrement())
  licenseKey       String           @unique // e.g. "EE-Basic-001"
  licenseType      String           // EE-Basic, EE-Standard, SBQ-Basic, SBQ-Standard
  snipeItLicenseId Int
  status           String           @default("Available") // Available, Assigned
  assignedToEmail  String?
  assignedToTicket String?
  history          LicenseHistory[]
  createdAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

model LicenseHistory {
  id               Int              @id @default(autoincrement())
  licenseId        Int
  license          LicenseInventory @relation(fields: [licenseId], references: [id])
  action           String           // e.g. "Assigned", "Released"
  assignedToEmail  String?
  details          String?
  timestamp        DateTime         @default(now())
}

model CredentialSheet {
  id              Int              @id @default(autoincrement())
  ticketId        Int              @unique
  ticket          OnboardingTicket @relation(fields: [ticketId], references: [id])
  fileName        String
  fileContent     String           // Base64 encoded file data
  fileType        String
  uploadedBy      String           // User name or email of uploader
  uploadedAt      DateTime         @default(now())
  passwordHint    String?
  downloadToken   String?          @unique
  tokenExpiresAt  DateTime?
}
